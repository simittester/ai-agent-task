# Copy this file to `.env` and fill in your real key.
# Get a free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-key-here

# Optional: override the default model.
# `gemini-2.5-flash` is the recommended default: 1500 requests/day on free
# tier for almost every account. Avoid `gemini-flash-latest` — it follows
# the newest model, which usually has the most restrictive free tier
# (e.g. only 20 requests/day at the time of writing).
GEMINI_MODEL=gemini-2.5-flash

# Optional: maximum number of tool-call rounds the agent will do before stopping.
AGENT_MAX_STEPS=6
