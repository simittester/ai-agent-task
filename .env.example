# Copy this file to `.env` and fill in your real key.
# Get a free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-key-here

# Optional: override the default model.
# `gemini-flash-latest` works on every account's free tier. Other free-tier
# options (depending on your account/region): gemini-2.5-flash,
# gemini-1.5-flash. `gemini-2.0-flash` is NOT free for some new accounts.
GEMINI_MODEL=gemini-flash-latest

# Optional: maximum number of tool-call rounds the agent will do before stopping.
AGENT_MAX_STEPS=6
